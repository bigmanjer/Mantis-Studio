# Streamlit native authentication configuration (example)
[auth]
# Redirect URI for Streamlit Cloud: https://<your-app>.streamlit.app/oauth2callback
# Redirect URI for local dev: http://localhost:8501/oauth2callback
redirect_uri = "http://localhost:8501/oauth2callback"
# Generate a long random string for cookie_secret (do not reuse in production).
cookie_secret = "replace-with-a-long-random-string"
# Optional: default account management URL for non-Google/Microsoft providers
provider_account_url = "https://your-idp.example.com/account"
# Optional: enable auth debug panel in Account page
debug_auth = false

[auth.google]
client_id = "replace-with-google-client-id"
client_secret = "replace-with-google-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[auth.microsoft]
client_id = "replace-with-microsoft-client-id"
client_secret = "replace-with-microsoft-client-secret"
# Use your tenant ID or 'common' for multi-tenant.
server_metadata_url = "https://login.microsoftonline.com/<tenant-id>/v2.0/.well-known/openid-configuration"

[auth.apple]
client_id = "replace-with-apple-client-id"
client_secret = "replace-with-apple-client-secret"
server_metadata_url = "https://appleid.apple.com/.well-known/openid-configuration"

# Optional: email/passwordless OIDC provider (used by "Continue with Email")
[auth.email]
client_id = "replace-with-email-oidc-client-id"
client_secret = "replace-with-email-oidc-client-secret"
server_metadata_url = "https://your-email-idp.example.com/.well-known/openid-configuration"

# Optional: third-party OIDC provider
[auth.other]
client_id = "replace-with-oidc-client-id"
client_secret = "replace-with-oidc-client-secret"
server_metadata_url = "https://your-issuer.example.com/.well-known/openid-configuration"

[authz]
# Optional: restrict access to specific domains or emails
allowed_domains = ["example.com"]
allowed_emails = ["admin@example.com"]
# Optional: mark admin users (used for admin-only pages)
admin_emails = ["admin@example.com"]
